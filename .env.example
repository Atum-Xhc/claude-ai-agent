# Skopiuj ten plik jako .env i uzupelnij wartosci
# cp .env.example .env

# Klucz API Anthropic – pobierz z https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-twoj-klucz-tutaj

# Model (opcjonalnie, domyslnie claude-3-5-sonnet-20241022)
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Maksymalna liczba tokenow w odpowiedzi
MAX_TOKENS=4096
